# "development" | "production". Production tightens the demo-reset guard.
APP_ENV=development

# Neon Postgres connection string (pooled endpoint recommended).
# Get it from the Neon console: Project -> Connect -> Connection string.
DATABASE_URL=postgresql://USER:PASSWORD@ep-your-endpoint.aws.neon.tech/neondb?sslmode=require

# Redis for the ARQ job queue (defaults to local Redis when unset).
REDIS_URL=redis://localhost:6379/0

# Seconds to pause between worker pipeline stages (demo pacing; 0 = fastest).
WORKER_STAGE_DELAY_S=0

# Comma-separated allowed browser origins. Set to the deployed web origin in
# production; never "*".
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limit for POST /v1/jobs, per client IP (slowapi syntax).
RATE_LIMIT_JOBS=10/minute
RATE_LIMIT_ENABLED=true

# Sentry error reporting (leave empty to disable).
SENTRY_DSN=

# --- Object storage (Cloudflare R2 or S3) -----------------------------------
# Leave S3_BUCKET empty to use the local filesystem backend (dev default).
S3_BUCKET=
# R2 endpoint: https://<account_id>.r2.cloudflarestorage.com (empty for AWS S3)
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
SIGNED_URL_EXPIRY_S=3600

# Local artifact backend (used when S3_BUCKET is empty).
# ARTIFACT_DIR defaults to apps/api/var/artifacts.
ARTIFACT_SIGNING_SECRET=change-me-in-production
PUBLIC_BASE_URL=http://127.0.0.1:8000

# --- Anonymous private sessions (Phase C) ---------------------------------
SESSION_COOKIE_NAME=nomos_session
# Empty for local host-only cookies. Production: .nomosorbital.com
SESSION_COOKIE_DOMAIN=
SESSION_TTL_DAYS=30
SHARE_LINK_DEFAULT_TTL_DAYS=7
