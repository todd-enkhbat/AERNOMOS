# Neon Postgres connection string (pooled endpoint recommended).
# Get it from the Neon console: Project -> Connect -> Connection string.
DATABASE_URL=postgresql://USER:PASSWORD@ep-your-endpoint.aws.neon.tech/neondb?sslmode=require

# Redis for the ARQ job queue (defaults to local Redis when unset).
REDIS_URL=redis://localhost:6379/0

# Seconds to pause between worker pipeline stages (demo pacing; 0 = fastest).
WORKER_STAGE_DELAY_S=0
